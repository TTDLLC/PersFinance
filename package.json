{
  "name": "persfinance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/copy-assets.mjs",
    "start": "node dist/src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "seed:dev": "tsx scripts/seed.ts --dev",
    "test:balance": "npm run build && node dist/scripts/check-balance.js",
    "test:register": "npm run build && node dist/scripts/check-register.js",
    "test:step2": "npm run build && node dist/scripts/check-step2.js",
    "test:import": "npm run build && node dist/scripts/check-import.js",
    "test:large-import": "npm run build && node dist/scripts/check-large-import.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-flash": "^0.1.1",
    "connect-pg-simple": "^9.0.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "method-override": "^3.0.0",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/connect-flash": "^0.0.40",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/method-override": "^0.0.35",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
