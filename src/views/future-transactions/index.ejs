<section class="page-header row">
  <div><h1>Future Transactions</h1><p>One-off planned items and scenario assumptions.</p></div>
  <a class="button" href="/future-transactions/new">New Future Item</a>
</section>
<table>
  <thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Type</th><th>Account</th><th>Scenario</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% if (!futureTransactions.length) { %>
      <tr><td class="empty-state" colspan="8">No future transactions yet. Add one-off planned items or scenario assumptions.</td></tr>
    <% } %>
    <% futureTransactions.forEach((item) => { %>
      <tr>
        <td><%= item.date %></td><td><%= item.description %></td><td class="<%= signedClass(item.amount) %>"><%= money(item.amount) %></td><td><%= label(item.transactionType) %></td><td><%= item.accountName || "" %></td><td><%= item.scenarioName || "" %></td><td><span class="status"><%= label(item.status) %></span></td><td class="actions"><a href="/future-transactions/<%= item.id %>/edit">Edit</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
