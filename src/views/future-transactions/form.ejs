<section class="page-header"><h1><%= futureTransaction.id ? "Edit Future Transaction" : "New Future Transaction" %></h1></section>
<form method="post" action="<%= futureTransaction.id ? `/future-transactions/${futureTransaction.id}` : "/future-transactions" %>" class="form grid-form">
  <label>Date<input type="date" name="date" value="<%= futureTransaction.date || "" %>" required></label>
  <label>Description<input name="description" value="<%= futureTransaction.description || "" %>" required></label>
  <label>Amount<input type="number" step="0.01" name="amount" value="<%= futureTransaction.amount || "" %>" required></label>
  <label>Type<select name="transactionType"><% transactionTypes.forEach((type) => { %><option value="<%= type %>" <%= futureTransaction.transactionType === type ? "selected" : "" %>><%= label(type) %></option><% }) %></select></label>
  <label>Account<select name="accountId"><option value="">None</option><% accounts.forEach((account) => { %><option value="<%= account.id %>" <%= futureTransaction.accountId === account.id ? "selected" : "" %>><%= account.name %></option><% }) %></select></label>
  <label>Category<select name="categoryId"><option value="">None</option><% categories.forEach((category) => { %><option value="<%= category.id %>" <%= futureTransaction.categoryId === category.id ? "selected" : "" %>><%= category.name %></option><% }) %></select></label>
  <label>Scenario<select name="scenarioId"><option value="">None</option><% scenarios.forEach((scenario) => { %><option value="<%= scenario.id %>" <%= futureTransaction.scenarioId === scenario.id ? "selected" : "" %>><%= scenario.name %></option><% }) %></select></label>
  <label>Status<select name="status"><% statuses.forEach((status) => { %><option value="<%= status %>" <%= futureTransaction.status === status ? "selected" : "" %>><%= label(status) %></option><% }) %></select></label>
  <label class="checkbox"><input type="checkbox" name="includeInProjection" <%= futureTransaction.includeInProjection !== false ? "checked" : "" %>> Include in projection</label>
  <label class="full">Notes<textarea name="notes"><%= futureTransaction.notes || "" %></textarea></label>
  <div class="form-actions full"><button type="submit">Save</button><a href="/future-transactions">Cancel</a></div>
</form>
<% if (futureTransaction.id) { %><form method="post" action="/future-transactions/<%= futureTransaction.id %>/delete"><button class="danger" type="submit">Delete Future Transaction</button></form><% } %>
