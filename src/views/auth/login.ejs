<section class="auth-panel">
  <h1>Login</h1>
  <form method="post" action="/login" class="form">
    <label>Email
      <input type="email" name="email" required autofocus>
    </label>
    <label>Password
      <input type="password" name="password" required>
    </label>
    <button type="submit">Login</button>
  </form>
</section>
