<section class="page-header row">
  <div>
    <h1><%= scenario.name %></h1>
    <p><%= scenario.active ? "Active scenario overlay" : "Archived scenario" %></p>
  </div>
  <div class="form-actions">
    <a class="button secondary-button" href="/scenarios">Back to Scenarios</a>
    <a class="button" href="/scenarios/<%= scenario.id %>/items/new">Add Scenario Item</a>
  </div>
</section>

<div class="detail-layout">
  <div>
    <section class="card">
      <h2>Scenario</h2>
      <dl>
        <dt>Name</dt>
        <dd><%= scenario && scenario.name ? scenario.name : '' %></dd>
        <dt>Description</dt>
        <dd><%= scenario && scenario.description ? scenario.description : '—' %></dd>
        <dt>Notes</dt>
        <dd><%= scenario && scenario.notes ? scenario.notes : '—' %></dd>
        <dt>Status</dt>
        <dd><%= scenario && scenario.active ? 'Active' : 'Archived' %></dd>
        <dt>Accounts</dt>
        <dd>
          <% if (!accounts || !accounts.length) { %>
            <span class="muted">No linked accounts.</span>
          <% } else { %>
            <%= accounts.map((account) => account.name).join(", ") %>
          <% } %>
        </dd>
      </dl>
      <div class="form-actions">
        <a class="button" href="/scenarios/<%= scenario.id %>/edit">Edit Details</a>
        <% if (scenario.active) { %>
          <form method="post" action="/scenarios/<%= scenario.id %>/archive" class="inline-form">
            <button type="submit" class="secondary-button">Archive</button>
          </form>
        <% } %>
      </div>
    </section>
  </div>
  <div>
    <section class="card">
      <h2>Scenario Items</h2>
      <table>
        <thead>
          <tr>
            <th>Next</th>
            <th>Account</th>
            <th>Amount</th>
            <th>Name</th>
            <th>Frequency</th>
            <th>Category</th>
            <th>Payee</th>
            <th>Status</th>
            <th class="actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!items || !items.length) { %>
            <tr>
              <td class="empty-state" colspan="9">No scenario items yet.</td>
            </tr>
          <% } else { %>
            <% items.forEach((item) => { %>
              <tr class="<%= item.active ? "" : "muted" %>">
                <td><%= item.nextDueDate %></td>
                <td><%= item.accountName || item.accountId || "Unassigned" %></td>
                <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
                <td><%= item.name || '' %></td>
                <td><%= label(item.frequency) %></td>
                <td><%= item.categoryName || '' %></td>
                <td><%= item.payeeName || '' %></td>
                <td>
                  <span class="status"><%= item.includeInBaseline ? "Included in Baseline" : "Scenario Only" %></span>
                  <% if (!item.active) { %><span class="status">Archived</span><% } %>
                </td>
                <td class="actions">
                  <div class="account-actions">
                    <a class="small-button" href="/scenarios/<%= scenario.id %>/items/<%= item.id %>/edit">Edit</a>
                    <% if (item.active && !item.includeInBaseline) { %>
                      <form method="post" action="/scenarios/<%= scenario.id %>/items/<%= item.id %>/promote">
                        <button class="small-button" type="submit">Promote</button>
                      </form>
                    <% } %>
                    <% if (item.active) { %>
                      <form method="post" action="/scenarios/<%= scenario.id %>/items/<%= item.id %>/archive" onsubmit="return confirm('Archive this scenario item?');">
                        <button class="small-button" type="submit">Archive</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
      <p class="form-actions">
        <a class="button" href="/scenarios/<%= scenario.id %>/items/new">Add Scenario Item</a>
        <% if (accounts && accounts.length) { %>
          <a class="button secondary-button" href="/accounts/<%= accounts[0].id %>/forecast">Back to Forecast</a>
        <% } %>
      </p>
    </section>
  </div>
</div>
