<section class="page-header row">
  <div><h1>Monthly Projections</h1><p>Dynamically generated rows from current balances, recurring rules, and future items.</p></div>
</section>
<form class="filter-bar" method="get" action="/projections/monthly">
  <label>Start Date<input type="date" name="startDate" value="<%= options.startDate || "" %>"></label>
  <label>Months Ahead<input type="number" name="monthsAhead" min="1" max="60" value="<%= options.monthsAhead || 18 %>"></label>
  <label>Scenario
    <select name="scenarioId">
      <option value="">All / Unassigned</option>
      <% scenarios.forEach((scenario) => { %>
        <option value="<%= scenario.id %>" <%= options.scenarioId === scenario.id ? "selected" : "" %>><%= scenario.name %></option>
      <% }) %>
    </select>
  </label>
  <label>Account
    <select name="accountId">
      <option value="">All Projection Accounts</option>
      <% accounts.forEach((account) => { %>
        <option value="<%= account.id %>" <%= options.accountId === account.id ? "selected" : "" %>><%= account.name %></option>
      <% }) %>
    </select>
  </label>
  <label class="checkbox"><input type="checkbox" name="includeEstimates" <%= options.includeEstimates !== false ? "checked" : "" %>> Include estimates</label>
  <label class="checkbox"><input type="checkbox" name="includePending" <%= options.includePending !== false ? "checked" : "" %>> Include pending</label>
  <button type="submit">Update</button>
</form>
<h2>Monthly Summary</h2>
<table>
  <thead><tr><th>Month</th><th>Starting</th><th>Income</th><th>Expenses</th><th>Net</th><th>Ending</th><th>Lowest</th></tr></thead>
  <tbody>
    <% if (!monthlySummary.length) { %>
      <tr><td class="empty-state" colspan="7">No monthly projection data for the selected filters.</td></tr>
    <% } %>
    <% monthlySummary.forEach((row) => { %>
      <tr><td><%= row.month %></td><td><%= money(row.startingBalance) %></td><td class="amount positive"><%= money(row.incomeTotal) %></td><td class="amount negative"><%= money(row.expenseTotal) %></td><td class="<%= signedClass(row.netChange) %>"><%= money(row.netChange) %></td><td><%= money(row.endingBalance) %></td><td><%= money(row.lowestBalance) %></td></tr>
    <% }) %>
  </tbody>
</table>
<h2>Projection Rows</h2>
<table>
  <thead><tr><th>Date</th><th>Account</th><th>Description</th><th>Type</th><th>Status</th><th>Amount</th><th>Projected Balance</th><th>Source</th></tr></thead>
  <tbody>
    <% if (!rows.length) { %>
      <tr><td class="empty-state" colspan="8">No projection rows match the selected filters.</td></tr>
    <% } %>
    <% rows.forEach((row) => { %>
      <tr><td><%= row.date %></td><td><%= row.accountName %></td><td><%= row.description %></td><td><%= label(row.transactionType) %></td><td><span class="status"><%= label(row.status) %></span></td><td class="<%= signedClass(row.amount) %>"><%= money(row.amount) %></td><td><%= money(row.projectedBalance) %></td><td><%= label(row.sourceType) %></td></tr>
    <% }) %>
  </tbody>
</table>
