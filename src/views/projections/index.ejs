<section class="page-header">
  <h1>Projections</h1>
  <p>Upcoming register activity from <%= projection.filters.startDate %> through <%= projection.filters.endDate %>.</p>
</section>

<form class="filter-bar" method="get" action="/projections">
  <label>
    Account
    <select name="accountId">
      <option value="">All active accounts</option>
      <% projection.accountOptions.forEach((account) => { %>
        <option value="<%= account.id %>" <%= projection.filters.accountId === account.id ? "selected" : "" %>><%= account.name %></option>
      <% }) %>
    </select>
  </label>
  <label>
    Start date
    <input type="date" name="startDate" value="<%= projection.filters.startDate %>">
  </label>
  <label>
    End date
    <input type="date" name="endDate" value="<%= projection.filters.endDate %>">
  </label>
  <button type="submit">Update</button>
</form>

<table>
  <thead>
    <tr>
      <th>Account</th>
      <th>Date</th>
      <th>Description</th>
      <th>Status</th>
      <th>Amount</th>
      <th>Projected Balance</th>
    </tr>
  </thead>
  <tbody>
    <% if (!projection.rows.length) { %>
      <tr><td class="empty-state" colspan="6">No future register transactions match this projection window.</td></tr>
    <% } %>
    <% projection.rows.forEach((item) => { %>
      <tr class="future-row">
        <td><%= item.accountName %></td>
        <td><%= item.date %></td>
        <td><%= item.description %></td>
        <td><span class="status"><%= label(item.status) %></span></td>
        <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
        <td class="<%= signedClass(item.projectedBalance) %>"><%= accountingMoney(item.projectedBalance) %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
