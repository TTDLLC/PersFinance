<section class="page-header row">
  <div>
    <h1>Future Commitments</h1>
    <p>Expected future activity. Commitments do not affect register balances until entered.</p>
  </div>
  <a class="button" href="/commitments/new">New Commitment</a>
</section>

<form class="filter-bar" method="get" action="/commitments">
  <label>Payee
    <select name="payeeId">
      <option value="">All payees</option>
      <% filterPayees.forEach((payee) => { %>
        <option value="<%= payee.id %>" <%= filters.payeeId === payee.id ? "selected" : "" %>><%= payee.name %><%= payee.active ? "" : " (Archived)" %></option>
      <% }) %>
    </select>
  </label>
  <label>Account
    <select name="accountId">
      <option value="">All accounts</option>
      <% filterAccounts.forEach((account) => { %>
        <option value="<%= account.id %>" <%= filters.accountId === account.id ? "selected" : "" %>><%= account.name %><%= account.active ? "" : " (Archived)" %></option>
      <% }) %>
    </select>
  </label>
  <button type="submit">Update</button>
  <% if (filters.payeeId || filters.accountId || showAll) { %>
    <a href="/commitments">Clear</a>
  <% } %>
  <a class="button secondary-button filter-bar-end" href="<%= historyToggleHref %>"><%= showAll ? "Hide All History" : "Show All History" %></a>
</form>

<table>
  <thead><tr><th>Due</th><th>Name</th><th>Payee</th><th>Account</th><th>Category</th><th>Frequency</th><th>Amount</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% if (!commitments.length) { %><tr><td class="empty-state" colspan="9"><%= filters.payeeId || filters.accountId ? "No future commitments match the selected filters." : "No future commitments in this view." %></td></tr><% } %>
    <% commitments.forEach((item) => { %>
      <% const overdue = item.active && item.nextDueDate <= today && (!item.endDate || item.nextDueDate <= item.endDate); %>
      <tr class="<%= overdue ? "overdue-row" : "" %>">
        <td><%= item.nextDueDate %></td>
        <td>
          <%= item.name %>
          <% if (item.scenarioName) { %>
            <span class="status">Scenario: <%= item.scenarioName %></span>
          <% } %>
        </td>
        <td><%= item.payeeName || "" %></td>
        <td>
          <% if (item.kind === "transfer") { %>
            <%= item.transferFromAccountName || "From account" %> &rarr; <%= item.transferToAccountName || "To account" %>
          <% } else { %>
            <%= item.accountName || "Unassigned" %>
          <% } %>
        </td>
        <td><%= item.categoryName || "" %></td>
        <td><%= label(item.frequency) %></td>
        <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
        <td><span class="status"><%= overdue ? "Due" : (item.active ? "Active" : "Ended") %></span></td>
        <td class="actions">
          <% if (overdue) { %><a href="/commitments/<%= item.id %>/enter">Enter</a><% } %>
          <a href="/commitments/<%= item.id %>/edit">Edit</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
