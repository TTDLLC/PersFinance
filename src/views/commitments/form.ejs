<section class="page-header"><h1><%= commitment.id ? "Edit Future Commitment" : "New Future Commitment" %></h1></section>
<form id="commitment-form" method="post" action="<%= commitment.id ? `/commitments/${commitment.id}` : "/commitments" %>" class="form grid-form planning-form" data-commitment-kind-form>
  <% const commitmentKind = commitment.kind || "transaction"; %>
  <% const fromAccountId = commitment.fromAccountId || (commitmentKind === "transfer" ? commitment.transferFromAccountId : commitment.accountId) || ""; %>
  <fieldset class="radio-group planning-form-kind">
    <legend>Commitment Type</legend>
    <label class="checkbox"><input type="radio" name="kind" value="transaction" <%= commitmentKind === "transaction" ? "checked" : "" %>> Transaction</label>
    <label class="checkbox"><input type="radio" name="kind" value="transfer" <%= commitmentKind === "transfer" ? "checked" : "" %>> Transfer</label>
  </fieldset>
  <label class="planning-field-name">Name<input name="name" value="<%= commitment.name || "" %>" required></label>
  <label class="planning-field-payee">Payee<select name="payeeId"><option value="">None</option><% payees.forEach((item) => { %><option value="<%= item.id %>" <%= commitment.payeeId === item.id ? "selected" : "" %>><%= item.name %><%= item.active ? "" : " (Archived)" %></option><% }) %></select></label>
  <label class="planning-field-frequency">Frequency<select name="frequency"><% frequencies.forEach((item) => { %><option value="<%= item %>" <%= commitment.frequency === item ? "selected" : "" %>><%= label(item) %></option><% }) %></select></label>
  <label class="planning-field-from">From Account<select name="fromAccountId" required><option value="">Select account</option><% accounts.forEach((item) => { %><option value="<%= item.id %>" <%= fromAccountId === item.id ? "selected" : "" %>><%= item.name %><%= item.active ? "" : " (Archived)" %></option><% }) %></select></label>
  <label class="planning-field-amount">Amount<input type="number" step="0.01" name="amount" value="<%= commitment.amount || "" %>" required></label>
  <label class="planning-field-to">To Account<select name="transferToAccountId" data-commitment-to-account><option value="">Select account</option><% accounts.forEach((item) => { %><option value="<%= item.id %>" <%= commitment.transferToAccountId === item.id ? "selected" : "" %>><%= item.name %><%= item.active ? "" : " (Archived)" %></option><% }) %></select></label>
  <label class="planning-field-start">Start Date<input type="date" name="startDate" value="<%= commitment.startDate || "" %>" required></label>
  <label class="planning-field-next">Next Due Date<input type="date" name="nextDueDate" value="<%= commitment.nextDueDate || "" %>" required></label>
  <label class="planning-field-end">End Date<input type="date" name="endDate" value="<%= commitment.endDate || "" %>"></label>
  <label class="checkbox planning-field-active"><input type="checkbox" name="active" value="true" <%= commitment.active === true || commitment.active === "true" || commitment.active === "on" ? "checked" : "" %>> Active</label>
  <label class="full">Notes<textarea name="notes"><%= commitment.notes || "" %></textarea></label>
</form>
<% if (commitment.id && commitment.active) { %>
  <form id="commitment-end-form" method="post" action="/commitments/<%= commitment.id %>/archive"></form>
<% } %>
<div class="planning-form-actions">
  <div>
    <% if (commitment.id && commitment.active) { %>
      <button class="danger" type="submit" form="commitment-end-form">End Commitment</button>
    <% } %>
  </div>
  <div class="form-actions">
    <button type="submit" form="commitment-form">Save Commitment</button>
    <a class="button secondary-button" href="/commitments">Cancel</a>
  </div>
</div>
