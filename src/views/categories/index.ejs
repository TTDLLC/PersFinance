<section class="page-header row">
  <div><h1>Categories</h1><p>Drag active categories to change their order. Archived categories remain on historical rows.</p></div>
  <a class="button" href="/categories/new">New Category</a>
</section>

<form class="filter-bar" method="get" action="/categories">
  <input type="hidden" name="showArchived" value="false">
  <label class="checkbox">
    <input type="checkbox" name="showArchived" value="true" <%= showArchived ? "checked" : "" %>>
    Show archived
  </label>
  <button type="submit">Update</button>
</form>

<div class="sort-status" data-category-sort-status aria-live="polite"></div>
<table>
  <thead><tr><th class="drag-column"><span class="visually-hidden">Move</span></th><th>Name</th><th>Type</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% if (!categories.length) { %>
      <tr><td class="empty-state" colspan="5">No categories match the current filter.</td></tr>
    <% } %>
    <% categories.forEach((category) => { %>
      <tr
        class="<%= category.active ? "sortable-row" : "muted" %>"
        data-category-id="<%= category.id %>"
        draggable="<%= category.active ? "true" : "false" %>"
      >
        <td class="drag-handle"><%= category.active ? "::" : "" %></td>
        <td><%= category.name %></td>
        <td><%= label(category.type) %></td>
        <td><span class="status"><%= category.active ? "Active" : "Archived" %></span></td>
        <td class="actions"><a href="/categories/<%= category.id %>/edit">Edit</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
