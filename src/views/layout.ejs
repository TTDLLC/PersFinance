<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | PersFinance</title>
    <link rel="stylesheet" href="/css/app.css">
  </head>
  <body>
    <% const money = (value) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD" }).format(Number(value || 0)); %>
    <% const accountingMoney = (value) => { const numeric = Number(value || 0); const formatted = money(Math.abs(numeric)); return numeric < 0 ? `(${formatted})` : formatted; }; %>
    <% const signedClass = (value) => Number(value || 0) < 0 ? "amount negative" : "amount positive"; %>
    <% const label = (value) => String(value || "").split("_").map((part) => part.charAt(0).toUpperCase() + part.slice(1)).join(" "); %>
    <%- include("partials/nav") %>
    <main class="app-shell">
      <%- include("partials/flash") %>
      <% if (typeof overdueCommitmentCount !== "undefined" && overdueCommitmentCount > 0) { %>
        <div class="commitment-alert" role="status">
          You have <strong><%= overdueCommitmentCount %></strong> overdue commitment<%= overdueCommitmentCount === 1 ? "" : "s" %> requiring review.
          <a href="/commitments">Review commitments</a>
        </div>
      <% } %>
      <%- include(view, { money, accountingMoney, signedClass, label }) %>
    </main>
    <script src="/js/app.js"></script>
  </body>
</html>
