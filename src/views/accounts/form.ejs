<section class="page-header"><h1><%= account.id ? "Edit Account" : "New Account" %></h1></section>
<form method="post" action="<%= account.id ? `/accounts/${account.id}` : "/accounts" %>" class="form grid-form">
  <label>Name<input name="name" value="<%= account.name || "" %>" required></label>
  <label>Type<select name="type"><% accountTypes.forEach((type) => { %><option value="<%= type %>" <%= account.type === type ? "selected" : "" %>><%= label(type) %></option><% }) %></select></label>
  <label>Starting Balance
    <% if (!startingInformationState.editable) { %><input type="hidden" name="startingInformationBalance" value="<%= account.startingInformationBalance || "0.00" %>"><% } %>
    <input type="number" step="0.01" name="<%= startingInformationState.editable ? "startingInformationBalance" : "" %>" value="<%= account.startingInformationBalance || "0.00" %>" <%= startingInformationState.editable ? "" : "disabled" %>>
  </label>
  <label>Starting Date
    <% if (!startingInformationState.editable) { %><input type="hidden" name="startingInformationDate" value="<%= account.startingInformationDate || "" %>"><% } %>
    <input type="date" name="<%= startingInformationState.editable ? "startingInformationDate" : "" %>" value="<%= account.startingInformationDate || "" %>" <%= startingInformationState.editable ? "" : "disabled" %> required>
  </label>
  <label class="full">Starting Notes
    <% if (!startingInformationState.editable) { %><input type="hidden" name="startingInformationNotes" value="<%= account.startingInformationNotes || "" %>"><% } %>
    <textarea name="<%= startingInformationState.editable ? "startingInformationNotes" : "" %>" <%= startingInformationState.editable ? "" : "disabled" %>><%= account.startingInformationNotes || "" %></textarea>
  </label>
  <label>Display Order<input type="number" name="displayOrder" value="<%= account.displayOrder || 0 %>"></label>
  <% if (startingInformationState.warning) { %>
    <div class="panel full">
      <h2>Starting Information Warning</h2>
      <p>This account has activity but no reconciled statement yet. Changing Starting Information will also change the statement-chain balance anchor.</p>
    </div>
  <% } %>
  <% if (!startingInformationState.editable) { %>
    <div class="panel full">
      <h2>Starting Information Locked</h2>
      <p>Starting Information is locked because this account has a reconciled statement.</p>
    </div>
  <% } %>
  <label class="full">Notes<textarea name="notes"><%= account.notes || "" %></textarea></label>
  <div class="form-actions full"><button type="submit">Save</button><a href="/accounts">Cancel</a></div>
</form>
<% if (account.id && account.active) { %><form method="post" action="/accounts/<%= account.id %>/archive"><button class="danger" type="submit">Archive Account</button></form><% } %>
