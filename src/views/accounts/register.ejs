<section class="page-header row">
  <div>
    <h1><%= register.account.name %> Register</h1>
    <p>Current Balance <%= money(register.balance.currentBalance) %>; reconciliation <%= register.displayLastReconciledDate || "not reconciled yet" %>.</p>
  </div>
  <a class="button" href="/accounts/<%= register.account.id %>/register/new">New Transaction</a>
</section>

<form class="filter-bar" method="get" action="/accounts/<%= register.account.id %>/register">
  <label>View
    <select name="view">
      <option value="active" <%= register.view === "active" ? "selected" : "" %>>Active</option>
      <option value="all" <%= register.view === "all" ? "selected" : "" %>>Show All</option>
      <option value="void" <%= register.view === "void" ? "selected" : "" %>>Void</option>
    </select>
  </label>
  <button type="submit">Update</button>
</form>

<section class="panel status-help">
  <h2>Status Guide</h2>
  <p><strong>Entered</strong>, <strong>Pending</strong>, and <strong>Cleared</strong> active transactions affect Current Balance.</p>
  <p>Reconciled transactions are assigned to statements. Void transactions affect nothing and only appear in the Void view.</p>
</section>

<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Payee</th>
      <th>Description</th>
      <th>Category</th>
      <th>Amount</th>
      <th>Status</th>
      <th>Balance After</th>
      <th>Edit</th>
      <th>Void</th>
    </tr>
  </thead>
  <tbody>
    <% if (!register.rows.length) { %>
      <tr><td class="empty-state" colspan="9">No transactions in this view.</td></tr>
    <% } %>
    <% register.rows.forEach((item) => { %>
      <tr class="<%= item.status === "void" ? "void-row" : "" %>">
        <td><%= item.date %></td>
        <td><%= item.payeeName %></td>
        <td><%= item.description || "" %></td>
        <td><%= item.categoryName || "" %></td>
        <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
        <td><span class="status"><%= label(item.status) %></span></td>
        <td class="<%= signedClass(item.balanceAfter) %>"><%= accountingMoney(item.balanceAfter) %></td>
        <td class="actions">
          <% if (item.canEdit) { %>
            <a href="/accounts/<%= register.account.id %>/register/<%= item.id %>/edit">Edit</a>
          <% } else { %>
            <span class="muted">Locked</span>
          <% } %>
        </td>
        <td class="actions">
          <% if (item.canVoid) { %>
            <form method="post" action="/accounts/<%= register.account.id %>/register/<%= item.id %>/void">
              <button class="link-button danger-link" type="submit">Void</button>
            </form>
          <% } else { %>
            <span class="muted">-</span>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
