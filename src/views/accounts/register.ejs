<section class="page-header row">
  <div>
    <h1><%= register.account.name %> Register</h1>
    <p>
      <% if (register.displayLastReconciledDate) { %>
        Reconciled on <%= register.displayLastReconciledDate %>, Balance: <%= money(register.balance.statementBalance) %>
      <% } else { %>
        Not reconciled yet, Balance: <%= money(register.balance.statementBalance) %>
      <% } %>
    </p>
  </div>
  <div class="form-actions">
    <a class="button" href="/accounts/<%= register.account.id %>/register/new">New Transaction</a>
    <a class="button secondary-button" href="/accounts/<%= register.account.id %>/statements">Statements</a>
    <a class="button secondary-button" href="/accounts/<%= register.account.id %>/edit">Account Settings</a>
  </div>
</section>

<section class="table-panel">
  <form class="filter-bar embedded-filter" method="get" action="/accounts/<%= register.account.id %>/register">
    <label>View
      <select name="view">
        <option value="active" <%= register.view === "active" ? "selected" : "" %>>Active</option>
        <option value="all" <%= register.view === "all" ? "selected" : "" %>>Show All</option>
        <option value="void" <%= register.view === "void" ? "selected" : "" %>>Void</option>
      </select>
    </label>
    <button type="submit">Update</button>
  </form>
  <table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Payee</th>
      <th>Description</th>
      <th>Category</th>
      <th>Amount</th>
      <th>Status</th>
      <th>Balance After</th>
      <th>Edit</th>
    </tr>
  </thead>
  <tbody>
    <% if (!register.rows.length) { %>
      <tr><td class="empty-state" colspan="8">No transactions in this view.</td></tr>
    <% } %>
    <% register.rows.forEach((item) => { %>
      <tr class="<%= item.status === "void" ? "void-row" : "" %>">
        <td><%= item.date %></td>
        <td><%= item.payeeName %></td>
        <td><%= item.description || "" %></td>
        <td><%= item.categoryName || "" %></td>
        <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
        <td><span class="status"><%= label(item.status) %></span></td>
        <td class="<%= signedClass(item.balanceAfter) %>"><%= accountingMoney(item.balanceAfter) %></td>
        <td class="actions">
          <% if (item.canEdit) { %>
            <a href="/accounts/<%= register.account.id %>/register/<%= item.id %>/edit">Edit</a>
          <% } else { %>
            <span class="muted">Locked</span>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
  </table>
</section>
