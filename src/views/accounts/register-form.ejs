<section class="page-header"><h1><%= transaction.id ? "Edit Transaction" : "New Transaction" %></h1></section>
<form method="post" action="<%= transaction.id ? `/accounts/${account.id}/register/${transaction.id}` : `/accounts/${account.id}/register` %>" class="form grid-form">
  <label>Date<input type="date" name="date" value="<%= transaction.date || "" %>" required></label>
  <label>Payee
    <select name="payeeId">
      <option value="">Select payee</option>
      <% payees.forEach((payee) => { %><option value="<%= payee.id %>" <%= transaction.payeeId === payee.id ? "selected" : "" %>><%= payee.name %><%= payee.active ? "" : " (Archived)" %></option><% }) %>
    </select>
  </label>
  <div class="field-help">Need another payee? <a href="/payees">Manage payees</a>.</div>
  <label>Category<select name="categoryId"><option value="">None</option><% categories.forEach((category) => { %><option value="<%= category.id %>" <%= transaction.categoryId === category.id ? "selected" : "" %>><%= category.name %><%= category.active ? "" : " (Archived)" %></option><% }) %></select></label>
  <label>Amount<input type="number" step="0.01" name="amount" value="<%= transaction.amount || "" %>" required></label>
  <label>Status<select name="status"><% statuses.forEach((status) => { %><option value="<%= status %>" <%= (transaction.status || "entered") === status ? "selected" : "" %>><%= label(status) %></option><% }) %></select></label>
  <label class="full">Description<textarea name="description"><%= transaction.description || "" %></textarea></label>
  <p class="field-help full">A Payee or Description is required.</p>
  <label class="full">Notes<textarea name="notes"><%= transaction.notes || "" %></textarea></label>
  <div class="form-actions full"><button type="submit">Save Transaction</button><a href="/accounts/<%= account.id %>/register">Cancel</a></div>
</form>
<% if (transaction.id && ["entered", "pending", "cleared"].includes(transaction.status) && !transaction.statementId) { %>
  <form method="post" action="/accounts/<%= account.id %>/register/<%= transaction.id %>/void">
    <button class="danger" type="submit">Void Transaction</button>
  </form>
<% } %>
