<section class="page-header row">
  <div><h1>Register</h1><p>Actual account transactions.</p></div>
  <a class="button" href="/transactions/new">New Transaction</a>
</section>

<form class="filter-bar" method="get" action="/transactions">
  <label>Account
    <select name="accountId">
      <option value="">All Accounts</option>
      <% accounts.forEach((account) => { %>
        <option value="<%= account.id %>" <%= filters.accountId === account.id ? "selected" : "" %>><%= account.name %></option>
      <% }) %>
    </select>
  </label>
  <label>View
    <select name="view">
      <option value="active" <%= filters.view === "active" ? "selected" : "" %>>Active</option>
      <option value="all" <%= filters.view === "all" ? "selected" : "" %>>Show All</option>
      <option value="void" <%= filters.view === "void" ? "selected" : "" %>>Void</option>
    </select>
  </label>
  <button type="submit">Update</button>
</form>

<table>
  <thead><tr><th>Date</th><th>Payee</th><th>Description</th><th>Account</th><th>Category</th><th>Status</th><th>Amount</th><th></th></tr></thead>
  <tbody>
    <% if (!transactions.length) { %>
      <tr><td class="empty-state" colspan="8">No register transactions yet.</td></tr>
    <% } %>
    <% transactions.forEach((item) => { %>
      <tr>
        <td><%= item.date %></td>
        <td><%= item.payeeName %></td>
        <td><%= item.description || "" %></td>
        <td><%= item.accountName || "" %></td>
        <td><%= item.categoryName || "" %></td>
        <td><span class="status"><%= label(item.status) %></span></td>
        <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
        <td class="actions"><a href="/transactions/<%= item.id %>/edit">Edit</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
