<section class="page-header row">
  <div><h1>Register</h1><p>Account activity and working balances from statement snapshots.</p></div>
  <a class="button" href="/transactions/new">New Transaction</a>
</section>

<section class="metric-grid">
  <% balances.forEach((balance) => { %>
    <article class="metric-card">
      <span><%= balance.accountName %></span>
      <strong><%= money(balance.workingBalance) %></strong>
      <p>Snapshot <%= balance.latestSnapshotDate || "none" %> at <%= money(balance.latestSnapshotBalance) %>; activity <%= money(balance.postSnapshotActivityTotal) %></p>
    </article>
  <% }) %>
</section>

<form class="filter-bar" method="get" action="/transactions">
  <label>Account
    <select name="accountId">
      <option value="">All Accounts</option>
      <% accounts.forEach((account) => { %>
        <option value="<%= account.id %>" <%= filters.accountId === account.id ? "selected" : "" %>><%= account.name %></option>
      <% }) %>
    </select>
  </label>
  <label class="checkbox"><input type="checkbox" name="includeArchived" <%= filters.includeArchived ? "checked" : "" %>> Show archived</label>
  <button type="submit">Update</button>
</form>

<table>
  <thead><tr><th>Date</th><th>Description</th><th>Account</th><th>Category</th><th>Type</th><th>Status</th><th>Amount</th><th></th></tr></thead>
  <tbody>
    <% if (!transactions.length) { %>
      <tr><td class="empty-state" colspan="8">No register transactions yet.</td></tr>
    <% } %>
    <% transactions.forEach((item) => { %>
      <tr>
        <td><%= item.date %></td>
        <td><%= item.description %></td>
        <td><%= item.accountName || "" %></td>
        <td><%= item.categoryName || "" %></td>
        <td><%= item.transactionType || "" %></td>
        <td><span class="status"><%= label(item.status) %><%= item.amountType === "estimate" ? " Estimate" : "" %></span></td>
        <td class="<%= signedClass(item.amount) %>"><%= money(item.amount) %></td>
        <td class="actions"><a href="/transactions/<%= item.id %>/edit">Edit</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
