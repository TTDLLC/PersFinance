<section class="page-header">
  <h1>Dashboard</h1>
  <p>Account-register overview for the 1.0 workflow.</p>
</section>

<section class="metric-grid">
  <article class="metric-card"><span>Working Balance</span><strong><%= money(metrics.totalWorkingBalance) %></strong></article>
  <article class="metric-card"><span>Snapshot Balance</span><strong><%= money(metrics.totalSnapshotBalance) %></strong></article>
  <article class="metric-card"><span>Post-Snapshot Activity</span><strong><%= money(metrics.totalPostSnapshotActivity) %></strong></article>
  <article class="metric-card"><span>Active Accounts</span><strong><%= metrics.accountCount %></strong></article>
</section>

<section class="placeholder-grid">
  <div class="panel">
    <h2>Register Balances</h2>
    <table class="compact-table">
      <thead><tr><th>Account</th><th>Snapshot</th><th>Activity</th><th>Working</th></tr></thead>
      <tbody>
        <% if (!workingBalances.length) { %>
          <tr><td class="empty-state" colspan="4">No register balances yet.</td></tr>
        <% } %>
        <% workingBalances.forEach((balance) => { %>
          <tr><td><%= balance.accountName %></td><td><%= balance.latestSnapshotDate || "None" %></td><td class="<%= signedClass(balance.postSnapshotActivityTotal) %>"><%= money(balance.postSnapshotActivityTotal) %></td><td><%= money(balance.workingBalance) %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="panel">
    <h2>Projection rebuild</h2>
    <p>Projection charts and planning summaries will return after they are rebuilt from register transactions.</p>
  </div>
</section>
