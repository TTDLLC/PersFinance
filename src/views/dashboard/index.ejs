<section class="page-header row">
  <div>
    <h1>Dashboard</h1>
    <p>Upcoming operational items for the next 14 days.</p>
  </div>
  <div class="form-actions">
    <a class="button" href="/commitments/new">New Commitment</a>
    <a class="button secondary-button" href="/commitments">Future Commitments</a>
  </div>
</section>

<section class="table-panel">
  <div class="section-heading">
    <h2>Upcoming Future Commitments</h2>
  </div>
  <table>
    <thead>
      <tr>
        <th>Due</th>
        <th>Commitment</th>
        <th>Account</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!upcomingCommitments.length) { %>
        <tr><td class="empty-state" colspan="6">No future commitments due in the next 14 days.</td></tr>
      <% } %>
      <% upcomingCommitments.forEach((item) => { %>
        <% const overdue = item.nextDueDate < today; %>
        <tr class="<%= overdue ? "overdue-row" : "" %>">
          <td><%= item.nextDueDate %></td>
          <td>
            <%= item.name %>
            <% if (item.payeeName) { %>
              <div class="hint"><%= item.payeeName %></div>
            <% } %>
          </td>
          <td>
            <% if (item.kind === "transfer") { %>
              <%= item.transferFromAccountName || "From account" %> &rarr; <%= item.transferToAccountName || "To account" %>
            <% } else { %>
              <%= item.accountName || "Unassigned" %>
            <% } %>
          </td>
          <td class="<%= signedClass(item.amount) %>"><%= accountingMoney(item.amount) %></td>
          <td><span class="status"><%= overdue ? "Overdue" : "Upcoming" %></span></td>
          <td class="actions">
            <a class="small-button" href="/commitments/<%= item.id %>/enter"><%= overdue ? "Enter" : "Enter Early" %></a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
