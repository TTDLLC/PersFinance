<section class="page-header">
  <h1>Dashboard</h1>
</section>

<table>
  <thead>
    <tr>
      <th>Account</th>
      <th>Type</th>
      <th>Current Balance</th>
      <th>Reconciliation</th>
    </tr>
  </thead>
  <tbody>
    <% if (!accounts.length) { %>
      <tr><td class="empty-state" colspan="4">No accounts yet.</td></tr>
    <% } %>
    <% accounts.forEach((account) => { %>
      <tr>
        <td><a href="/accounts/<%= account.id %>/register"><%= account.name %></a></td>
        <td><%= label(account.type) %></td>
        <td class="<%= signedClass(account.currentBalance) %>"><%= money(account.currentBalance) %></td>
        <td><%= account.lastReconciledDate || "Not reconciled yet" %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
